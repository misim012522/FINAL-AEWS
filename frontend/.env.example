# API base URL for the backend (optional; defaults to http://localhost:8000)
# VITE_API_URL=http://localhost:8000

# Google reCAPTCHA v2 site key for the visible "I'm not a robot" checkbox.
# Create at https://www.google.com/recaptcha/admin → reCAPTCHA v2 → "I'm not a robot" Checkbox.
# VITE_RECAPTCHA_SITE_KEY=your_reCAPTCHA_v2_site_key_here
