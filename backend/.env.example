# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=capstonesystem

SECRET_KEY=your-secret-key-change-in-production
PORT=8000

# Frontend URL for verification links (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Gmail only – for verification/confirmation emails
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
FROM_EMAIL=your-email@gmail.com

# reCAPTCHA v2 secret key (from https://www.google.com/recaptcha/admin, v2 "I'm not a robot" Checkbox).
# Must match the v2 site key used in the frontend. Do not use a v3 secret key here.
# RECAPTCHA_SECRET_KEY=your_reCAPTCHA_v2_secret_key
